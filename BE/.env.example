# Local Docker Compose defaults for the auth/gateway/user-profile stack.
# Copy to BE/.env for local use. Do not commit real secrets.

API_GATEWAY_PORT=3000

AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change-me-auth-db-password

USER_PROFILE_DB_USER=user_profile_user
USER_PROFILE_DB_PASSWORD=change-me-user-profile-db-password

RABBITMQ_USER=stylemind
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_VHOST=stylemind

JWT_SECRET=change-me-local-jwt-secret-at-least-32-characters
JWT_KEY_PATH=
INTERNAL_SERVICE_SECRET=change-me-local-internal-service-secret

