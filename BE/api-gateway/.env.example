# API Gateway local development environment.
# Copy to .env for local use. Do not commit real secrets.

SERVER_PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=3600
GATEWAY_CONNECT_TIMEOUT_MS=3000
GATEWAY_RESPONSE_TIMEOUT=5s
GATEWAY_RETRY_SAFE_RETRIES=1

AUTH_SERVICE_URL=http://auth-service:8081
USER_PROFILE_SERVICE_URL=http://user-profile-service:8082
USER_SERVICE_URL=http://user-profile-service:8082

REDIS_URL=redis://redis:6379
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

RABBITMQ_URL=amqp://stylemind:change-me-rabbitmq-password@rabbitmq:5672/stylemind
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=stylemind
SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq-password
SPRING_RABBITMQ_VIRTUAL_HOST=stylemind

JWT_SECRET=change-me-local-jwt-secret-at-least-32-characters
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_PATH=
JWT_KEY_PATH=
INTERNAL_SERVICE_SECRET=change-me-local-internal-service-secret
INTERNAL_TOKEN=change-me-local-internal-service-secret

GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_FAIL_OPEN=true
GATEWAY_RATE_LIMIT_REDIS_TIMEOUT=250ms
GATEWAY_RATE_LIMIT_LOGIN_IP_LIMIT=10
GATEWAY_RATE_LIMIT_LOGIN_IP_WINDOW=60s
GATEWAY_RATE_LIMIT_LOGIN_IDENTIFIER_LIMIT=10
GATEWAY_RATE_LIMIT_LOGIN_IDENTIFIER_WINDOW=300s
GATEWAY_RATE_LIMIT_REGISTER_IP_LIMIT=5
GATEWAY_RATE_LIMIT_REGISTER_IP_WINDOW=60s
GATEWAY_RATE_LIMIT_FORGOT_PASSWORD_IP_LIMIT=5
GATEWAY_RATE_LIMIT_FORGOT_PASSWORD_IP_WINDOW=60s
GATEWAY_RATE_LIMIT_FORGOT_PASSWORD_IDENTIFIER_LIMIT=5
GATEWAY_RATE_LIMIT_FORGOT_PASSWORD_IDENTIFIER_WINDOW=900s
GATEWAY_RATE_LIMIT_REFRESH_IP_LIMIT=30
GATEWAY_RATE_LIMIT_REFRESH_IP_WINDOW=60s
GATEWAY_RATE_LIMIT_AI_CHAT_LIMIT=5
GATEWAY_RATE_LIMIT_AI_CHAT_WINDOW=60s
