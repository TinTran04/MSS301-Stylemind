# Auth Service local development environment.
# Copy to .env for local use. Do not commit real secrets.

SERVER_PORT=8081

DATABASE_URL=jdbc:postgresql://auth-postgres:5432/auth_db
SPRING_DATASOURCE_URL=jdbc:postgresql://auth-postgres:5432/auth_db
SPRING_DATASOURCE_USERNAME=auth_user
SPRING_DATASOURCE_PASSWORD=change-me-auth-db-password

REDIS_URL=redis://redis:6379
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

RABBITMQ_URL=amqp://stylemind:change-me-rabbitmq-password@rabbitmq:5672/stylemind
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=stylemind
SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq-password
SPRING_RABBITMQ_VIRTUAL_HOST=stylemind
RABBITMQ_EVENTS_EXCHANGE=stylemind.events
RABBITMQ_EVENTS_DLX=stylemind.events.dlx
RABBITMQ_USER_REGISTERED_ROUTING_KEY=user.registered
RABBITMQ_USER_REGISTERED_QUEUE=user-profile.user-registered
RABBITMQ_USER_REGISTERED_DLQ=user-profile.user-registered.dlq
RABBITMQ_USER_REGISTERED_DLQ_ROUTING_KEY=user.registered.dlq
AUTH_OUTBOX_PUBLISHER_ENABLED=true
AUTH_OUTBOX_PUBLISHER_BATCH_SIZE=20
AUTH_OUTBOX_PUBLISHER_FIXED_DELAY_MS=5000
AUTH_OUTBOX_PUBLISHER_INITIAL_DELAY_MS=5000
AUTH_OUTBOX_CONFIRM_TIMEOUT_MS=5000

JWT_SECRET=change-me-local-jwt-secret-at-least-32-characters
JWT_KEY_PATH=
INTERNAL_SERVICE_SECRET=change-me-local-internal-service-secret
INTERNAL_TOKEN=change-me-local-internal-service-secret

SPRING_MAIN_ALLOW_CIRCULAR_REFERENCES=true
