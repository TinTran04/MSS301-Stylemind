{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stylemind.local/contracts/events/user-registered.schema.json",
  "title": "USER_REGISTERED",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "data"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "USER_REGISTERED"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "userId",
        "fullName"
      ],
      "properties": {
        "userId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "fullName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 150
        }
      }
    }
  }
}
